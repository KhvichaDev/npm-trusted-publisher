{
  "name": "npm-trusted-publisher",
  "version": "2.1.0",
  "description": "A zero-config CLI tool and GitHub Actions workflow for secure, automated npm publishing. Replaces NPM_TOKEN with OIDC, automatically syncs versions, updates changelogs, commits build artifacts, and enables provenance-backed releases.",
  "files": [
    "bin",
    "templates",
    "CHANGELOG.md"
  ],
  "bin": {
    "npm-trusted-publisher": "./bin/cli.js"
  },
  "keywords": [
    "npm",
    "publish",
    "trusted-publishing",
    "github-actions",
    "workflow",
    "ci-cd",
    "automation",
    "provenance",
    "release",
    "npm-publish",
    "oidc",
    "semver",
    "changelog",
    "continuous-delivery",
    "drop-in"
  ],
  "author": "KhvichaDev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KhvichaDev/npm-trusted-publisher"
  },
  "homepage": "https://github.com/KhvichaDev/npm-trusted-publisher#readme",
  "bugs": {
    "url": "https://github.com/KhvichaDev/npm-trusted-publisher/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
